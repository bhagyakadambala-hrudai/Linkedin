# --- Supabase (required for LinkedIn callback + exchange) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- LinkedIn OAuth (required for /api/linkedin/callback) ---
# Redirect URI must be EXACTLY (set in LinkedIn Developer Console):
#   https://linkedin-saas-three.vercel.app/api/linkedin/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# --- Frontend (required for redirect after OAuth) ---
FRONTEND_URL=https://linkedin-saas-three.vercel.app

# --- Vite (frontend) — do not commit .env.local ---
# Required for "Connect LinkedIn" button; must be set or you'll see "LinkedIn client ID not configured"
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
VITE_API_BASE_URL=http://localhost:3000
